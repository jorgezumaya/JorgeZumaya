rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Gallery metadata: public read, no client write
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else is written server-side via Cloud Function (admin SDK bypasses rules)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
