rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /Resume/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    match /Gallery/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
