# Angular injects variables prefixed with NG_APP_ at build time.
# Copy this file to .env and fill in your values.
# Find these in the Firebase console: Project Settings > Your apps > Web app.

NG_APP_FIREBASE_API_KEY=your-api-key
NG_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NG_APP_FIREBASE_PROJECT_ID=your-project-id
NG_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NG_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NG_APP_FIREBASE_APP_ID=1:your-sender-id:web:your-app-id
NG_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# reCAPTCHA v3 site key — Firebase console > App Check > reCAPTCHA v3
NG_APP_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
